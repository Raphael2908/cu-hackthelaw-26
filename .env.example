# Copy to backend/.env to override defaults. The stack boots with NONE of these set (mock mode).

# --- Runtime ---
ENV=development                  # development | production
PROVIDER_MODE=mock               # mock (replays fixtures, no key) | real (Anthropic)
LOG_LEVEL=info

# --- API / CORS ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost

# --- Store ---
SQLITE_PATH=data/cockpit.sqlite  # created on boot; :memory: also works

# --- Dispatch / Celery --- worker→checker→ranker runs off-request on a Celery worker (needs Redis).
# Set ASYNC_DISPATCH=false to run the pipeline inline in-process (no broker) — the offline fallback.
ASYNC_DISPATCH=true
CELERY_BROKER_URL=redis://localhost:6379/0     # docker compose overrides to redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- LLM (Anthropic) --- blank = mock mode; set both to use a real model
ANTHROPIC_API_KEY=               # sk-ant-...   (real mode fails loudly if blank)
ANTHROPIC_MODEL=claude-opus-4-8

# --- EU Cellar (live citation source, see architecture.md §7.1/§9) --- opt-in. OFF = fixtures only,
# fully offline. When on, the citation-support signal fetches a source by CELEX from the EU
# Publications Office on a corpus miss and caches it; fixtures remain the offline fallback.
CELLAR_ENABLED=false
CELLAR_BASE_URL=http://publications.europa.eu
CELLAR_LANGUAGE=en
CELLAR_TIMEOUT=10.0

# --- Risk signal tuning (see architecture.md §7) ---
SAMPLE_RATE=0.2                  # fraction of auto-cleared items pulled into review (audit sampling)
DISAGREEMENT_RUNS=3             # multi-run disagreement: how many times to re-run the review
W_CITATION=0.5                  # uncertainty weight: citation support
W_DEVIATION=0.3                 # uncertainty weight: precedent deviation
W_DISAGREEMENT=0.2             # uncertainty weight: multi-run disagreement

# --- Frontend (frontend/.env.local) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
