# ---- Runtime ----
ENV=development                 # development | production
ROLE=api                        # api | worker | beat (set per container)
PROVIDER_MODE=mock              # mock | real  (mock = no keys needed, canned data)
LOG_LEVEL=info

# ---- API / CORS ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Supabase (DB + Auth) ----
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=       # client key (sb_publishable_...)
SUPABASE_SECRET_KEY=            # server service-role key (sb_secret_...)

# ---- AWS / S3 (uploaded documents + outputs) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET=

# ---- LLM (Anthropic Claude) ----
ANTHROPIC_API_KEY=
LLM_MODEL_PLANNER=claude-opus-4-8       # planner + coordinator (deep reasoning)
LLM_MODEL_AGENT=claude-sonnet-4-6       # web / doc / rerank / synth (throughput)
LLM_MODEL_EVAL=claude-opus-4-8          # evaluator (risk/uncertainty judgement)

# ---- Web research (Perplexity) ----
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# ---- EU legal corpus (CELLAR) ----
CELLAR_BASE_URL=https://publications.europa.eu/webapi/rdf/sparql

# ---- Reranker ----
RERANK_MODE=deterministic       # deterministic | cohere
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# ---- Pipeline defaults / guards ----
DEFAULT_EVAL_DOC_COUNT=5        # N: docs the evaluator scrutinises (lawyer-overridable per task)
MAX_INFLIGHT_TASKS=20
RATE_LIMIT_PER_MIN=60
VENDOR_CONCURRENCY_LLM=8
VENDOR_CONCURRENCY_PERPLEXITY=4
TASK_MAX_RETRIES=3
AGENT_TIMEOUT_S=240

# ---- Email (optional) ----
RESEND_API_KEY=

# ---- Frontend (build-time, baked into the bundle) ----
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
