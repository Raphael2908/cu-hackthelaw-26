# Copy to backend/.env to override defaults. The stack boots with NONE of these set (mock mode).

# --- Runtime ---
ENV=development                  # development | production
PROVIDER_MODE=mock               # mock (replays fixtures, no key) | real (Anthropic)
LOG_LEVEL=info

# --- API / CORS ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost

# --- Store ---
SQLITE_PATH=data/cockpit.sqlite  # created on boot; :memory: also works

# --- LLM (Anthropic) --- blank = mock mode; set both to use a real model
ANTHROPIC_API_KEY=               # sk-ant-...   (real mode fails loudly if blank)
ANTHROPIC_MODEL=claude-opus-4-8

# --- Risk signal tuning (see architecture.md §7) ---
SAMPLE_RATE=0.2                  # fraction of auto-cleared items pulled into review (audit sampling)
DISAGREEMENT_RUNS=3             # multi-run disagreement: how many times to re-run the review
W_CITATION=0.5                  # uncertainty weight: citation support
W_DEVIATION=0.3                 # uncertainty weight: precedent deviation
W_DISAGREEMENT=0.2             # uncertainty weight: multi-run disagreement

# --- Frontend (frontend/.env.local) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
