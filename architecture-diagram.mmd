%% Legal Drafting Copilot — agent pipeline
%% Render at https://mermaid.live or any Mermaid-capable slide tool.
flowchart LR
    IN["Legal brief <i>(task)</i><br/><span style='font-size:11px'>+ documents + N</span>"]
    PL["Planner<br/><span style='font-size:11px'>decomposes the task</span>"]
    CO["Coordinator<br/><span style='font-size:11px'>dispatches agents</span>"]
    WEB["Web agent<br/><span style='font-size:11px'>Perplexity · CELLAR (EU)</span>"]
    DOC["Doc agent<br/><span style='font-size:11px'>uploaded documents</span>"]
    RR["Reranker<br/><span style='font-size:11px'>ranks by relevance</span>"]
    EV["Evaluator<br/><span style='font-size:11px'>scrutinises top-N</span>"]
    SY["Synthesiser<br/><span style='font-size:11px'>drafts the argument</span>"]
    OUT["Argument<br/><span style='font-size:11px'>cited draft</span>"]

    IN --> PL -->|plan.md| CO
    CO --> WEB
    CO --> DOC
    WEB --> RR
    DOC --> RR
    RR --> EV --> SY --> OUT

    N{{"N = how many top documents to review<br/>— set by the lawyer"}}
    N -.-> EV

    classDef orch fill:#eef2ff,stroke:#6366f1,stroke-width:2px,color:#0f172a;
    classDef research fill:#ecfdf5,stroke:#10b981,stroke-width:2px,color:#0f172a;
    classDef rank fill:#fffbeb,stroke:#f59e0b,stroke-width:2px,color:#0f172a;
    classDef eval fill:#fef2f2,stroke:#ef4444,stroke-width:2px,color:#0f172a;
    classDef synth fill:#faf5ff,stroke:#a855f7,stroke-width:2px,color:#0f172a;
    classDef io fill:#eef2f7,stroke:#64748b,stroke-width:2px,color:#0f172a;
    classDef out fill:#0f172a,stroke:#0f172a,stroke-width:2px,color:#ffffff;
    classDef note fill:#fff1f2,stroke:#fecaca,stroke-width:1px,color:#b91c1c;

    class IN io;
    class PL,CO orch;
    class WEB,DOC research;
    class RR rank;
    class EV eval;
    class SY synth;
    class OUT out;
    class N note;
